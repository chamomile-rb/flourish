module Flourish
  class Style
    EMPTY: Style

    def initialize: () -> void

    # Text attributes
    def bold: (?bool v) -> Style
    def italic: (?bool v) -> Style
    def faint: (?bool v) -> Style
    def blink: (?bool v) -> Style
    def strikethrough: (?bool v) -> Style
    def underline: (?bool v) -> Style
    def reverse: (?bool v) -> Style

    # Colors
    def foreground: (String? color) -> Style
    def background: (String? color) -> Style

    # Utility
    def tab_width: (Integer n) -> Style
    def inline: (?bool v) -> Style
    def transform: () { (String) -> String } -> Style

    # Dimensions
    def width: (Integer n) -> Style
    def height: (Integer n) -> Style
    def max_width: (Integer n) -> Style
    def max_height: (Integer n) -> Style

    # Padding (CSS shorthand)
    def padding: (*Integer args) -> Style
    def padding_top: (Integer n) -> Style
    def padding_right: (Integer n) -> Style
    def padding_bottom: (Integer n) -> Style
    def padding_left: (Integer n) -> Style

    # Margin (CSS shorthand)
    def margin: (*Integer args) -> Style
    def margin_top: (Integer n) -> Style
    def margin_right: (Integer n) -> Style
    def margin_bottom: (Integer n) -> Style
    def margin_left: (Integer n) -> Style

    # Border
    def border: (untyped style, *bool sides) -> Style
    def border_style: (untyped style) -> Style
    def border_top: (?bool v) -> Style
    def border_right: (?bool v) -> Style
    def border_bottom: (?bool v) -> Style
    def border_left: (?bool v) -> Style
    def border_foreground: (*String colors) -> Style
    def border_background: (*String colors) -> Style

    # Alignment
    def align: (*Float positions) -> Style
    def align_horizontal: (Float pos) -> Style
    def align_vertical: (Float pos) -> Style

    # Whitespace
    def underline_spaces: (?bool v) -> Style
    def strikethrough_spaces: (?bool v) -> Style
    def color_whitespace: (?bool v) -> Style

    # Query
    def bold?: () -> bool
    def italic?: () -> bool
    def faint?: () -> bool
    def blink?: () -> bool
    def strikethrough?: () -> bool
    def underline?: () -> bool
    def reverse?: () -> bool
    def inline?: () -> bool
    def foreground_color: () -> untyped?
    def background_color: () -> untyped?
    def border_top?: () -> bool
    def border_right?: () -> bool
    def border_bottom?: () -> bool
    def border_left?: () -> bool

    # Composition
    def inherit: (Style other) -> Style
    def merge: (Style? other) -> Style
    def unset: (*Symbol props) -> Style
    def set?: (Symbol prop) -> bool
    def copy: () -> Style

    # Render
    def render: (*String strs) -> String
  end
end
